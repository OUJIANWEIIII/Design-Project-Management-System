generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                 String                @id @default(cuid())
  name               String
  level              String
  division           String
  requestType        String
  status             String                @default("NOT_STARTED")
  designOwnerId      String?
  designOwner        Designer?             @relation("ProjectOwner", fields: [designOwnerId], references: [id])
  designerIds        String                @default("[]")
  startDate          DateTime?
  targetDeliveryDate DateTime?
  autoDeliveryDate   DateTime?
  alignmentDate      DateTime?
  deliveryDate       DateTime?
  completedAt        DateTime?
  scheduleStoppedAt  DateTime?
  isUnscheduled      Boolean               @default(true)
  allowReminder      Boolean               @default(true)
  currentRoundIndex  Int                   @default(1)
  notes              String                @default("")
  scheduleItems      ProjectScheduleItem[]
  rounds             ProjectRound[]
  feedbackEvents     FeedbackEvent[]
  reminders          Reminder[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([status])
  @@index([level])
  @@index([division])
}

model ProjectRound {
  id                 String                @id @default(cuid())
  projectId          String
  project            Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roundIndex         Int
  level              String
  status             String                @default("IN_PROGRESS")
  designerIds        String                @default("[]")
  startDate          DateTime?
  targetDeliveryDate DateTime?
  autoDeliveryDate   DateTime?
  alignmentDate      DateTime?
  deliveryDate       DateTime?
  allowReminder      Boolean               @default(true)
  submittedAt        DateTime?
  feedbackReceivedAt DateTime?
  notes              String                @default("")
  scheduleItems      ProjectScheduleItem[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@unique([projectId, roundIndex])
  @@index([projectId])
  @@index([status])
}

model FeedbackEvent {
  id                 String   @id @default(cuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roundIndex         Int
  submittedAt        DateTime @default(now())
  feedbackReceivedAt DateTime?
  notes              String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([projectId])
}

model Designer {
  id            String    @id @default(cuid())
  name          String    @unique
  role          String
  isDesignOwner Boolean   @default(false)
  isDesigner    Boolean   @default(true)
  isActive      Boolean   @default(true)
  ownedProjects Project[] @relation("ProjectOwner")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProjectScheduleItem {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roundId         String?
  round           ProjectRound? @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundIndex      Int      @default(1)
  date            DateTime
  workdayIndex    Int
  phaseName       String
  isAlignmentNode Boolean  @default(false)
  isDeliveryNode  Boolean  @default(false)
  designerIds     String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([projectId])
  @@index([roundId])
}

model Reminder {
  id             String         @id @default(cuid())
  dedupeKey      String?        @unique
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roundIndex     Int?
  type           String
  scheduledAt    DateTime
  sentAt         DateTime?
  channel        String         @default("企业微信群机器人")
  status         String         @default("PENDING")
  messageContent String
  errorMessage   String         @default("")
  retryCount     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@index([projectId])
}

model ReminderSendLock {
  id          String   @id @default(cuid())
  key         String   @unique
  projectId   String?
  roundIndex  Int?
  type        String
  scheduledAt DateTime?
  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([type])
}

model Settings {
  id               String   @id @default("default")
  wechatWebhookUrl String   @default("")
  workdayRule      String   @default("MONDAY_TO_FRIDAY")
  reminderTimes    String   @default("项目创建后立即；对齐前一天；对齐当天上午；交付前一天；交付当天上午；每周一上午")
  levelRules       String   @default("{\"A\":8,\"B\":8,\"C\":6,\"D\":2}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
